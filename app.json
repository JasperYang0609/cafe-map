    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ansai.cafemap",
      "config": {
        "googleMapsApiKey": "AIzaSyCtAEBCtImo5zDXYj0ZS5FevJcP9be70l8"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "我們需要你的位置來顯示附近的咖啡廳",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ansai.cafemap",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F0",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCtAEBCtImo5zDXYj0ZS5FevJcP9be70l8"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
