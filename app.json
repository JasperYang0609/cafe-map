      [
        "expo-location",
        {
          "locationWhenInUsePermission": "我們需要你的位置來顯示附近的咖啡廳"
        }
      ]
    ],
    "scheme": "cafemap",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65269658-1b91-4072-9abb-1d676abb8d17"
      }
    },
    "owner": "jasperyang",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/65269658-1b91-4072-9abb-1d676abb8d17"
    }
  }
